+async function flatpakBuildInit (options, manifest) {
+  const args = ['build-init']
+  addCommandLineOption(args, 'arch', options.arch)
+  if (manifest.base) {
+    addCommandLineOption(args, 'base', manifest.base)
+    addCommandLineOption(args, 'base-version', manifest['base-version'])
+  }
+  args.push(options['build-dir'])
+  args.push(manifest.id)
+  args.push(manifest.sdk)
+  args.push(manifest.runtime)
+  if (manifest['runtime-version']) args.push(manifest['runtime-version'])
+  return spawnWithLogging(options, 'flatpak', args)
+}
+
+async function flatpakBuildFinish (options, manifest) {
+  const args = ['build-finish']
+  if (manifest.command) addCommandLineOption(args, 'command', manifest.command)
+  if (manifest['finish-args']) {
+    for (const arg of manifest['finish-args']) {
+      args.push(arg)
+    }
+  }
+  args.push(options['build-dir'])
+  return spawnWithLogging(options, 'flatpak', args)
+}
