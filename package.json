{
  "name": "suopwatcher",
  "version": "0.1.0",
  "description": "Website change monitor",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "package:flatpak": "electron-vite build && electron-builder --linux flatpak",
    "dist": "rm -rf out dist && electron-vite build && electron-builder --linux flatpak",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && patch-package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/diff": "^7.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "patch-package": "^8.0.1",
    "svelte": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "diff": "^7.0.0"
  },
  "build": {
    "appId": "com.suop.watcher",
    "productName": "suopWatcher",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "linux": {
      "target": [
        "flatpak"
      ],
      "category": "Utility",
      "desktop": {
        "StartupWMClass": "suopwatcher"
      }
    },
    "flatpak": {
      "license": "LICENSE",
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "25.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "25.08",
      "finishArgs": [
        "--socket=x11",
        "--socket=wayland",
        "--share=ipc",
        "--share=network",
        "--device=dri",
        "--talk-name=org.freedesktop.Notifications",
        "--persist=."
      ]
    }
  }
}
